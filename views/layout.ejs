<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head", { page, pageCss, pageMeta, site }) %>
  <body class="app-body-shell">
    <div class="grain-background"></div>
    <div class="app-shell">
      <%- include("partials/header", { site, page }) %>
      <%- include("partials/mobile_nav", { pages, currentPage }) %>

      <div class="shell-grid">
        <main class="page-shell">
          <%- include("partials/page_intro", { page, site }) %>
          <%- include("pages/" + currentPage, { site }) %>
        </main>
      </div>

      <%- include("partials/footer", { site }) %>
    </div>

    <script id="grainwatch-data" type="application/json"><%- serializedData %></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/ethers@6.13.5/dist/ethers.umd.min.js"></script>
    <script src="/js/shared.js"></script>
    <script src="<%= pageScript %>"></script>
  </body>
</html>
