<section class="page-intro">
  <div class="page-intro-copy">
    <% const introIconByPage = { markets: "market", dashboard: "overview", reports: "report", oracle: "chain", alerts: "alert", settings: "settings" }; %>
    <p class="page-eyebrow">
      <%- include("icon", { name: introIconByPage[page.slug], className: "icon-sm" }) %>
      <span><%= page.eyebrow %></span>
    </p>
    <h2 class="page-title"><%= page.heading %></h2>
    <p class="page-description"><%= page.description %></p>
  </div>

  <div class="page-intro-stat-grid">
    <article class="page-intro-stat">
      <p class="page-intro-stat-label">Feed cadence</p>
      <p class="page-intro-stat-value"><%= site.meta.refreshLabel %></p>
    </article>
    <article class="page-intro-stat">
      <p class="page-intro-stat-label">Base mode</p>
      <p class="page-intro-stat-value"><%= site.baseDesk.mode %></p>
    </article>
    <article class="page-intro-stat">
      <p class="page-intro-stat-label">Market focus</p>
      <p class="page-intro-stat-value"><%= site.meta.focus %></p>
    </article>
  </div>
</section>
