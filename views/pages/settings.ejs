<section class="settings-grid">
  <div class="settings-hero-grid">
    <article class="settings-hero-card">
      <p class="settings-hero-label">Control Surface</p>
      <h3 class="settings-hero-title">Configuration should feel like a command center, not a form dump.</h3>
      <p class="settings-hero-copy">Thresholds, notification preferences, data sources, and API routes are grouped so operators can understand policy, source health, and sync behavior without hunting across disconnected panels.</p>
      <div class="settings-hero-metrics">
        <article class="settings-hero-metric">
          <p class="settings-hero-metric-label">Thresholds</p>
          <p class="settings-hero-metric-value"><%= Object.keys(site.settings.thresholds).length %> values</p>
        </article>
        <article class="settings-hero-metric">
          <p class="settings-hero-metric-label">Data sources</p>
          <p class="settings-hero-metric-value"><%= site.settings.dataSources.length %> feeds</p>
        </article>
        <article class="settings-hero-metric">
          <p class="settings-hero-metric-label">API routes</p>
          <p class="settings-hero-metric-value"><%= site.settings.apiRoutes.length %> endpoints</p>
        </article>
      </div>
    </article>

    <article class="settings-hero-card is-secondary">
      <p class="settings-hero-label">Engine State</p>
      <h3 class="settings-hero-title">The sync and prediction layer is easier to read at a glance now.</h3>
      <p class="settings-hero-copy">The settings surface keeps refresh policy, confidence scoring, and external integration status close together so operational changes are easier to reason about before teams ship them.</p>
      <div class="settings-hero-metrics">
        <article class="settings-hero-metric">
          <p class="settings-hero-metric-label">Mode</p>
          <p class="settings-hero-metric-value"><%= site.settings.engine.mode %></p>
        </article>
        <article class="settings-hero-metric">
          <p class="settings-hero-metric-label">Refresh</p>
          <p class="settings-hero-metric-value"><%= site.settings.engine.refreshInterval %></p>
        </article>
        <article class="settings-hero-metric">
          <p class="settings-hero-metric-label">Confidence</p>
          <p class="settings-hero-metric-value"><%= site.settings.engine.confidenceScores ? 'Enabled' : 'Disabled' %></p>
        </article>
      </div>
    </article>
  </div>

  <div class="settings-top-grid">
    <section class="settings-panel">
      <div class="panel-head">
        <div>
          <p class="panel-eyebrow">
            <%- include("../partials/icon", { name: "alert", className: "icon-sm" }) %>
            <span>Thresholds</span>
          </p>
          <h3 class="panel-title">Philippine Grain Thresholds</h3>
        </div>
        <button id="settingsSaveBtn" class="btn-primary">
          <%- include("../partials/icon", { name: "settings", className: "icon-sm" }) %>
          <span>Save Changes</span>
        </button>
      </div>
      <div class="settings-form-grid">
        <% Object.entries(site.settings.thresholds).forEach(([key, value]) => { %>
          <label class="settings-field">
            <span class="settings-field-label"><%= key.replace(/([A-Z])/g, " $1").replace(/^./, (char) => char.toUpperCase()) %> threshold</span>
            <input class="settings-input" type="number" value="<%= value %>" data-threshold="<%= key %>" />
          </label>
        <% }) %>
      </div>
    </section>

    <section class="settings-panel">
      <div class="panel-head">
        <div>
          <p class="panel-eyebrow">
            <%- include("../partials/icon", { name: "alert", className: "icon-sm" }) %>
            <span>Notifications</span>
          </p>
          <h3 class="panel-title">Operator Preferences</h3>
        </div>
      </div>
      <div class="settings-stack">
        <% site.settings.notifications.forEach((notification, index) => { %>
          <article class="settings-card">
            <div>
              <p class="settings-card-title"><%= notification.label %></p>
              <p class="settings-card-copy"><%= notification.description %></p>
            </div>
            <button class="settings-toggle <%= notification.enabled ? 'is-on' : '' %>" data-toggle-index="<%= index %>" type="button">
              <span></span>
            </button>
          </article>
        <% }) %>
      </div>
    </section>
  </div>

  <div class="settings-bottom-grid">
    <section class="settings-panel">
      <div class="panel-head">
        <div>
          <p class="panel-eyebrow">
            <%- include("../partials/icon", { name: "market", className: "icon-sm" }) %>
            <span>Sources</span>
          </p>
          <h3 class="panel-title">Data Source Status</h3>
        </div>
      </div>
      <div class="table-wrap">
        <table class="table-base">
          <thead>
            <tr>
              <th>Source</th>
              <th>Type</th>
              <th>Latency</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% site.settings.dataSources.forEach((source) => { %>
              <tr>
                <td class="strong"><%= source.source %></td>
                <td class="muted"><%= source.type %></td>
                <td class="mono muted"><%= source.latency %></td>
                <td><span class="settings-status-pill"><%= source.status %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="settings-panel">
      <div class="panel-head">
        <div>
          <p class="panel-eyebrow">
            <%- include("../partials/icon", { name: "settings", className: "icon-sm" }) %>
            <span>Engine</span>
          </p>
          <h3 class="panel-title">Prediction and Sync Controls</h3>
        </div>
      </div>
      <div class="settings-stack">
        <article class="settings-summary-card">
          <p class="settings-summary-label">Data mode</p>
          <p class="settings-summary-value"><%= site.settings.engine.mode %></p>
        </article>
        <article class="settings-summary-card">
          <p class="settings-summary-label">Refresh interval</p>
          <p class="settings-summary-value"><%= site.settings.engine.refreshInterval %></p>
        </article>
        <article class="settings-summary-card">
          <p class="settings-summary-label">Prediction sensitivity</p>
          <p class="settings-summary-value"><%= site.settings.engine.sensitivity %>%</p>
        </article>
        <article class="settings-summary-card">
          <p class="settings-summary-label">Confidence scores</p>
          <p class="settings-summary-value"><%= site.settings.engine.confidenceScores ? 'Enabled' : 'Disabled' %></p>
        </article>
      </div>
    </section>
  </div>
</section>
