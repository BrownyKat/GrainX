<section class="alerts-grid">
  <div class="alerts-hero-grid">
    <article class="alerts-hero-card">
      <p class="alerts-hero-label">Risk Watch</p>
      <h3 class="alerts-hero-title">Critical alerts should feel operationally urgent the moment the page opens.</h3>
      <p class="alerts-hero-copy">The active alert cards stay front-loaded, while the history and workflow panels below are structured to make ownership, closure logic, and recurrence tracking easier to review under pressure.</p>
      <div class="alerts-hero-metrics">
        <article class="alerts-hero-metric">
          <p class="alerts-hero-metric-label">Active alerts</p>
          <p class="alerts-hero-metric-value"><%= site.alerts.length %></p>
        </article>
        <article class="alerts-hero-metric">
          <p class="alerts-hero-metric-label">Workflow steps</p>
          <p class="alerts-hero-metric-value"><%= site.alertProcess.length %></p>
        </article>
        <article class="alerts-hero-metric">
          <p class="alerts-hero-metric-label">Resolution rules</p>
          <p class="alerts-hero-metric-value"><%= site.resolutionRules.length %></p>
        </article>
      </div>
    </article>

    <article class="alerts-hero-card is-secondary">
      <p class="alerts-hero-label">Closure Discipline</p>
      <h3 class="alerts-hero-title">The page now supports a clearer rhythm from breach to resolution.</h3>
      <p class="alerts-hero-copy">Active state, ownership history, and resolution rules are visually separated so teams can tell what is live, what closed cleanly, and what still needs a validated note.</p>
      <div class="alerts-hero-metrics">
        <article class="alerts-hero-metric">
          <p class="alerts-hero-metric-label">Current focus</p>
          <p class="alerts-hero-metric-value"><%= site.alerts[0].title %></p>
        </article>
        <article class="alerts-hero-metric">
          <p class="alerts-hero-metric-label">Owner desk</p>
          <p class="alerts-hero-metric-value">Retail / Logistics</p>
        </article>
        <article class="alerts-hero-metric">
          <p class="alerts-hero-metric-label">Monitoring window</p>
          <p class="alerts-hero-metric-value">24 hours</p>
        </article>
      </div>
    </article>
  </div>

  <div class="alerts-top-grid">
    <% site.alerts.forEach((alert) => { %>
      <article class="alert-card alert-<%= alert.type %>">
        <div class="alert-card-head">
          <p class="alert-card-title"><%= alert.title %></p>
          <span class="alert-card-badge"><%= alert.type %></span>
        </div>
        <p class="alert-card-copy"><%= alert.description %></p>
        <p class="alert-card-meta"><%= alert.meta %></p>
      </article>
    <% }) %>
  </div>

  <div class="alerts-bottom-grid">
    <section class="alerts-panel">
      <div class="panel-head">
        <div>
          <p class="panel-eyebrow">
            <%- include("../partials/icon", { name: "clock", className: "icon-sm" }) %>
            <span>History</span>
          </p>
          <h3 class="panel-title">Alert History and Closure Notes</h3>
        </div>
      </div>
      <div class="alerts-history-list">
        <% site.alertHistory.forEach((item) => { %>
          <article class="alerts-history-card">
            <div class="alerts-history-card-head">
              <div>
                <p class="alerts-history-date"><%= item.date %></p>
                <h4 class="alerts-history-title"><%= item.commodity %></h4>
              </div>
              <span class="alert-state-pill <%= item.state === 'Active' ? 'is-active' : 'is-resolved' %>"><%= item.state %></span>
            </div>

            <div class="alerts-history-meta-grid">
              <article class="alerts-history-meta-card">
                <p class="alerts-history-meta-label">Trigger</p>
                <p class="alerts-history-meta-value"><%= item.trigger %></p>
              </article>
              <article class="alerts-history-meta-card">
                <p class="alerts-history-meta-label">Value</p>
                <p class="alerts-history-meta-value mono"><%= item.value %></p>
              </article>
              <article class="alerts-history-meta-card">
                <p class="alerts-history-meta-label">Owner</p>
                <p class="alerts-history-meta-value"><%= item.owner %></p>
              </article>
            </div>

            <div class="alerts-history-resolution">
              <p class="alerts-history-meta-label">Resolution</p>
              <p class="alerts-history-resolution-copy"><%= item.resolution %></p>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="alerts-panel">
      <div class="panel-head">
        <div>
          <p class="panel-eyebrow">
            <%- include("../partials/icon", { name: "shield", className: "icon-sm" }) %>
            <span>Workflow</span>
          </p>
          <h3 class="panel-title">How an Alert Gets Resolved</h3>
        </div>
      </div>
      <div class="alerts-guide">
        <% site.alertProcess.forEach((step) => { %>
          <article class="guide-card">
            <p class="guide-title">Step <%= step.step %></p>
            <p class="strong"><%= step.title %></p>
            <p class="guide-copy"><%= step.description %></p>
            <p class="alert-card-meta"><%= step.outcome %></p>
          </article>
        <% }) %>
        <article class="guide-card">
          <p class="guide-title">Resolved Means</p>
        <% site.resolutionRules.forEach((rule) => { %>
            <p class="guide-copy label-with-icon">
              <%- include("../partials/icon", { name: "shield", className: "icon-sm" }) %>
              <span><%= rule %></span>
            </p>
          <% }) %>
        </article>
      </div>
    </section>
  </div>
</section>
