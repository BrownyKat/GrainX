<section class="markets-grid">
  <div class="markets-hero-grid">
    <article class="markets-hero-card">
      <p class="markets-hero-label">Trading Board</p>
      <h3 class="markets-hero-title">A clearer command surface for Philippine rice and corn decisions.</h3>
      <p class="markets-hero-copy">The market board, location explorer, and planner now sit under a stronger visual hierarchy so operators can scan the national picture, jump to city detail, and move straight into procurement planning.</p>
      <div class="markets-hero-metrics">
        <article class="markets-hero-metric">
          <p class="markets-hero-metric-label">Tracked grains</p>
          <p class="markets-hero-metric-value"><%= site.marketRows.length %> contracts</p>
        </article>
        <article class="markets-hero-metric">
          <p class="markets-hero-metric-label">Pilot locations</p>
          <p class="markets-hero-metric-value"><%= site.locationMarkets.length %> cities</p>
        </article>
        <article class="markets-hero-metric">
          <p class="markets-hero-metric-label">Hottest region</p>
          <p class="markets-hero-metric-value"><%= site.regions[0].region %></p>
        </article>
      </div>
    </article>

    <article class="markets-hero-card is-secondary">
      <p class="markets-hero-label">Operator Readiness</p>
      <h3 class="markets-hero-title">Move from board monitoring into procurement and Base attestation.</h3>
      <p class="markets-hero-copy">The planner highlights cost efficiency by city while the Base desk path stays prominent for teams that need a signed operating ticket tied to the selected grain and location.</p>
      <div class="markets-hero-metrics">
        <article class="markets-hero-metric">
          <p class="markets-hero-metric-label">Base mode</p>
          <p class="markets-hero-metric-value"><%= site.baseDesk.mode %></p>
        </article>
        <article class="markets-hero-metric">
          <p class="markets-hero-metric-label">Recommended tool</p>
          <p class="markets-hero-metric-value"><%= site.recommendedFunction.title %></p>
        </article>
        <article class="markets-hero-metric">
          <p class="markets-hero-metric-label">National focus</p>
          <p class="markets-hero-metric-value"><%= site.meta.focus %></p>
        </article>
      </div>
    </article>
  </div>

  <div class="markets-lead-grid">
    <section class="market-panel">
      <div class="panel-head">
        <div>
          <p class="panel-eyebrow">
            <%- include("../partials/icon", { name: "market", className: "icon-sm" }) %>
            <span>Philippine Grains Prices</span>
          </p>
          <h3 class="panel-title">Market Board</h3>
        </div>
      </div>
    </div>
    <div class="table-wrap">
      <table class="table-base">
        <thead>
          <tr>
            <th>Commodity</th>
            <th>Market Basis</th>
            <th>Last Price</th>
            <th>Daily Move</th>
            <th>Weekly</th>
            <th>Daily Range</th>
            <th>Lead Market</th>
          </tr>
        </thead>
        <tbody>
          <% site.marketRows.forEach((row) => { %>
            <tr>
              <td>
                <p class="strong"><%= row.commodity %></p>
                <p class="muted mono"><%= row.symbol %></p>
              </td>
              <td class="muted"><%= row.exchange %></td>
              <td class="mono"><%= row.spot.toFixed(1) %></td>
              <td class="mono <%= row.dailyChange.startsWith('+') ? 'tone-neon' : 'tone-danger' %>"><%= row.dailyChange %></td>
              <td class="mono <%= row.weekly.startsWith('+') ? 'tone-neon' : row.weekly.startsWith('-') ? 'tone-danger' : 'tone-amber' %>"><%= row.weekly %></td>
              <td class="mono muted"><%= row.low.toFixed(1) %> - <%= row.high.toFixed(1) %></td>
              <td class="muted"><%= row.leadLocation %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <div class="markets-lead-grid">
    <section class="market-panel">
      <div class="panel-head">
        <div>
          <p class="panel-eyebrow">
            <%- include("../partials/icon", { name: "location", className: "icon-sm" }) %>
            <span>Location Grain Prices</span>
          </p>
          <h3 class="panel-title">Location Explorer</h3>
        </div>
      </div>
      <div class="location-shell">
        <div class="location-toolbar">
          <label class="location-field">
            <span class="settings-field-label">Region</span>
            <select id="locationRegionSelect" class="location-select"></select>
          </label>
          <label class="location-field">
            <span class="settings-field-label">Province</span>
            <select id="locationProvinceSelect" class="location-select"></select>
          </label>
          <label class="location-field">
            <span class="settings-field-label">City / Municipality</span>
            <select id="locationSelect" class="location-select"></select>
          </label>
        </div>
        <p id="locationStatus" class="location-status-card">The market updates automatically when you change the region, province, or city.</p>

        <article class="location-summary-card">
          <div class="location-summary-hero">
            <div class="location-summary-topline">
              <p class="location-summary-kicker">Selected Market Profile</p>
              <div class="location-summary-pill-row">
                <span id="locationSource" class="heatmap-pill is-cool">Pilot Snapshot</span>
              </div>
            </div>
            <div class="location-summary-head">
              <p id="locationName" class="location-summary-title"><%= site.locationDefaults.selectedLocation %></p>
              <p id="locationMeta" class="location-summary-copy">Region, province, and city pricing with official-source mapping.</p>
            </div>
          </div>
          <div class="location-summary-stats">
            <article class="location-stat-card">
              <p class="location-stat-label">Region</p>
              <p id="locationRegionValue" class="location-stat-value">Region I (Ilocos Region)</p>
            </article>
            <article class="location-stat-card">
              <p class="location-stat-label">Province</p>
              <p id="locationProvinceValue" class="location-stat-value">Pangasinan</p>
            </article>
            <article class="location-stat-card">
              <p class="location-stat-label">Basket Delta</p>
              <p id="locationBasketValue" class="location-stat-value">Benchmark aligned</p>
            </article>
        </div>
      </article>

      <div id="locationCardGrid" class="location-card-grid"></div>

      <section class="comparison-shell">
        <div class="comparison-head">
          <div>
            <p class="panel-eyebrow">
              <%- include("../partials/icon", { name: "location", className: "icon-sm" }) %>
              <span>Comparison</span>
            </p>
            <h3 class="panel-title comparison-title">Compare Two Locations</h3>
          </div>
          <label class="comparison-field">
            <span class="settings-field-label">Compare Against</span>
            <input
              id="comparisonLocationInput"
              class="location-select"
              type="text"
              list="comparisonLocationOptions"
              placeholder="Type a city or municipality"
              autocomplete="off"
            />
            <datalist id="comparisonLocationOptions"></datalist>
          </label>
        </div>
        <div class="comparison-places-grid">
          <article class="comparison-focus-card">
            <p class="comparison-focus-label">Location A</p>
            <p id="comparisonPrimaryName" class="comparison-focus-value"><%= site.locationDefaults.selectedLocation %></p>
            <p id="comparisonPrimaryMeta" class="comparison-focus-copy">This follows the location selected in the explorer above.</p>
          </article>
          <article class="comparison-focus-card">
            <p class="comparison-focus-label">Location B</p>
            <p id="comparisonSecondaryName" class="comparison-focus-value">Choose a location</p>
            <p id="comparisonSecondaryMeta" class="comparison-focus-copy">Select another location to compare the current prices side by side.</p>
          </article>
        </div>
        <p id="comparisonStatus" class="location-status-card">Pick another place to compare its grain prices with the selected market.</p>
        <div id="comparisonSummary" class="comparison-summary-grid"></div>
        <div class="comparison-chart-shell">
          <div class="comparison-chart-canvas">
            <canvas id="locationComparisonChart"></canvas>
          </div>
        </div>
        <div class="table-wrap comparison-table-shell">
          <table class="table-base">
            <thead>
              <tr>
                <th>Grain</th>
                <th>Location A</th>
                <th>Location B</th>
                <th>Delta</th>
                <th>Cheaper Market</th>
              </tr>
            </thead>
            <tbody id="comparisonTableBody"></tbody>
          </table>
        </div>
      </section>
      </div>
    </section>

    <section class="market-panel">
      <div class="panel-head">
        <div>
          <p class="panel-eyebrow">
            <%- include("../partials/icon", { name: "shield", className: "icon-sm" }) %>
            <span>Operator Tool</span>
          </p>
          <h3 class="panel-title">Procurement and Wallet Exchange</h3>
        </div>
      </div>
      <div class="planner-shell">
        <div class="planner-context">
          <p class="planner-context-label">Using Selected Location</p>
          <p id="plannerLocationName" class="planner-context-value"><%= site.locationDefaults.selectedLocation %></p>
          <p id="plannerLocationMeta" class="planner-context-copy">Change the location in the explorer to update procurement planning automatically.</p>
        </div>
        <div class="planner-form-grid planner-form-grid-compact">
          <label class="planner-field">
            <span class="settings-field-label">Grain</span>
            <select id="plannerGrainSelect" class="location-select"></select>
          </label>
          <label class="planner-field">
            <span class="settings-field-label">Quantity (kg)</span>
            <input id="plannerQuantityInput" class="settings-input" type="number" min="1" value="1000" />
          </label>
        </div>
        <div id="plannerResult" class="planner-result"></div>
        <div class="planner-divider"></div>
        <section class="exchange-shell">
          <div class="exchange-head">
            <div>
              <p class="planner-result-label">Wallet Exchange Desk</p>
              <p class="planner-result-copy">Paper trading using the selected quote and the current ETH/PHP reference.</p>
            </div>
            <span id="exchangeModePill" class="heatmap-pill is-cool">Loading</span>
          </div>
          <div id="exchangeOverview" class="exchange-card-grid"></div>
          <div class="exchange-action-row">
            <button id="walletBuyBtn" class="btn-primary" type="button">
              <%- include("../partials/icon", { name: "spark", className: "icon-sm" }) %>
              <span>Buy Grain</span>
            </button>
            <button id="walletSellBtn" class="btn-ghost" type="button">
              <%- include("../partials/icon", { name: "report", className: "icon-sm" }) %>
              <span>Sell Grain</span>
            </button>
          </div>
          <p id="exchangeStatus" class="exchange-status">Connect a wallet to seed paper cash and simulate trades against the selected market.</p>
          <div id="exchangeHoldings" class="planner-result"></div>
          <div id="exchangeTrades" class="planner-result"></div>
        </section>
      </div>
    </section>
  </div>

  <div class="markets-chart-grid">
    <section class="market-panel">
      <div class="panel-head">
        <div>
          <p class="panel-eyebrow">
            <%- include("../partials/icon", { name: "trend", className: "icon-sm" }) %>
            <span>History</span>
          </p>
          <h3 class="panel-title">Tracked Grain Trend</h3>
        </div>
      </div>
      <div class="chart-frame">
        <canvas id="allCommoditiesChart"></canvas>
      </div>
    </section>

    <section class="market-panel">
      <div class="panel-head">
        <div>
          <p class="panel-eyebrow">
            <%- include("../partials/icon", { name: "location", className: "icon-sm" }) %>
            <span>Selected City</span>
          </p>
          <h3 class="panel-title">City Price Board</h3>
        </div>
      </div>
      <div class="chart-frame location-chart-frame">
        <div class="location-chart-canvas">
          <canvas id="locationPricesChart"></canvas>
        </div>
      </div>
    </section>
  </div>

  <section class="market-panel">
    <div class="panel-head">
      <div>
        <p class="panel-eyebrow">
          <%- include("../partials/icon", { name: "alert", className: "icon-sm" }) %>
          <span>Regional Pressure</span>
        </p>
        <h3 class="panel-title">Supply Chain Heat</h3>
      </div>
    </div>
    <div class="chart-frame chart-frame-tall">
      <canvas id="regionalPressureChart"></canvas>
    </div>
  </section>
</section>
